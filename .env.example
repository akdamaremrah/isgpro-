# ─── BACKEND (.env dosyası — backend/ klasörüne koy) ─────────────────────────

# AI API Anahtarları
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Veritabanı (Render'da otomatik set edilir, lokalde boş bırakın → SQLite kullanır)
DATABASE_URL=

# Public URL'ler (fotoğraf linkleri ve CORS için)
# Render'da backend URL'nizi girin, örn: https://isg-backend.onrender.com
BASE_URL=http://localhost:5000

# Frontend URL'si (CORS whitelist ve HTTP-Referer için)
# Render'da frontend URL'nizi girin, örn: https://isg-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Flask ortamı
FLASK_ENV=development


# ─── FRONTEND (.env.local dosyası — proje kök dizinine koy) ──────────────────

# Backend API URL'si
# Render'da backend URL'nizi girin, örn: https://isg-backend.onrender.com
VITE_API_URL=http://localhost:5000
